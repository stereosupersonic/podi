-# https://docs.podlove.org/podlove-web-player/v5/installation

%div{ id: webplayer_id, style: "opacity:0; transition:opacity 0.3s" }
%audio{ id: "#{webplayer_id}-fallback", controls: true, preload: "none", style: "display:none" }
  %source{ src: audio_url, type: "audio/mpeg" }
:javascript
  (function() {
    var attempts = 0;
    var id = "#{webplayer_id}";
    function initPlayer() {
      var container = document.getElementById(id);
      var fallback = document.getElementById(id + "-fallback");
      if (!container || !fallback) return;
      if (typeof podlovePlayer === "function") {
        fallback.remove();
        podlovePlayer("#" + id, #{episode_config}, #{player_config}).then(function() {
          container.style.opacity = "1";
        });
      } else if (attempts < 50) {
        attempts++;
        setTimeout(initPlayer, 100);
      } else {
        fallback.style.display = "";
      }
    }
    initPlayer();
  })();
